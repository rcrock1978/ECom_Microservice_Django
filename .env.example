# Root environment variable template for Mango E-Commerce Microservices

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=mango_dev
DATABASE_USER=mango
DATABASE_PASSWORD=mango_pass

# RabbitMQ
RABBITMQ_URL=amqp://mango:mango_pass@rabbitmq:5672/

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-secret-key

# Django settings
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Email
EMAIL_HOST=smtp
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# Stripe (for order service)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
